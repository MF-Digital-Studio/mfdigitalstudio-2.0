{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "mfdigitalstudio.com"
        }
      ],
      "destination": "https://www.mfdigitalstudio.com/$1",
      "permanent": true
    },
